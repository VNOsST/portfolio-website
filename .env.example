# Cloudflare R2 public bucket base URL
# Replace with your actual R2 public URL or custom domain
VITE_R2_PUBLIC_URL=https://your-bucket.r2.dev

# Cloudflare Worker URL for Spotify activity
# Replace with your actual deployed worker URL
VITE_SPOTIFY_WORKER_URL=https://spotify-activity-worker.your-subdomain.workers.dev
